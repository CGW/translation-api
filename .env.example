# Copy this to .env for local development
# On Railway, set these in the Variables tab (never commit .env to git)

# Required: A secret key Base44 sends in the X-API-Key header
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your-secret-key-here

# Required in production: Your Railway app's public URL
# Railway sets this automatically as RAILWAY_PUBLIC_DOMAIN
# Format: https://your-app-name.up.railway.app
BASE_URL=https://your-app-name.up.railway.app

# Optional: Restrict CORS to your Base44 app domain
# Leave as * during development
ALLOWED_ORIGIN=https://your-base44-app.base44.app

# Railway sets PORT automatically — don't change this
# PORT=3000
